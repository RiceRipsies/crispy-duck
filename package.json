{
  "name": "crispy-duck",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "NODE_ENV=production node server/src/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
